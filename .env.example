# Required for Vercel (and local) build. Add these in Vercel: Project Settings → Environment Variables.
# Get keys at https://dashboard.clerk.com/last-active?path=api-keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Keep Discord bot online across Vercel deploys (cron pings the bot every 5 min)
BOT_PUBLIC_URL=https://your-bot.up.railway.app
CRON_SECRET=
