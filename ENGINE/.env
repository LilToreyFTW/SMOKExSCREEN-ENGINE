# ── Discord OAuth ──────────────────────────────────────────────────────────────
# Create an app at https://discord.com/developers/applications
# Add redirect URI: https://smok-ex-screen-engine.vercel.app/auth/discord/callback
# Add redirect URI: https://smok-ex-screen-engine.vercel.app/auth/discord/engine-landing
DISCORD_CLIENT_ID=1476913890620342444
DISCORD_CLIENT_SECRET=2ujqdM-k6R4caMtYp2nDzqaN-3blP9vc

# ── Security ──────────────────────────────────────────────────────────────────
# Random secret for /admin/keys/add — generate with: openssl rand -hex 32
ADMIN_SECRET=2ujqdM-TOREY-k6R4caMtY

# ── App ───────────────────────────────────────────────────────────────────────
# Your Vercel deployment URL (no trailing slash)
