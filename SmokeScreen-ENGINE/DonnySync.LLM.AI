# DonnySync.LLM.AI — Sync the AI to all systems
# Automates notifies, login/register notifies, new user live page visit, Discord perms

[SYNC]
version=1.0
description=Donny AI syncs to ENGINE.exe, SmokeScreenEngine.exe, web, Discord

[EVENTS]
# Events that trigger Discord (and other) notifies. All enabled by default.
AUTOMATES_NOTIFYS=1
LOGIN_NOTIFY=1
REGISTER_NOTIFY=1
NEW_USER_LIVE_PAGE_VISIT=1
KEY_REDEEM_NOTIFY=1
SYSTEM_HEALTH=1
ENGINE_PING=1

[EVENT_SOURCES]
# Where each event is emitted (server = Express, bot = Discord bot, engine = ENGINE.exe)
LOGIN_NOTIFY=server
REGISTER_NOTIFY=server
NEW_USER_LIVE_PAGE_VISIT=server
KEY_REDEEM_NOTIFY=server
AUTOMATES_NOTIFYS=bot
SYSTEM_HEALTH=bot
ENGINE_PING=engine

[DISCORD_BOT_PERMISSIONS]
# Additional permissions for the current Discord bot token (OAuth2 URL or integer).
# Add these to the bot invite URL so the bot can manage all systems.
# Permission names (Discord API): https://discord.com/developers/docs/topics/permissions
permission_names=ViewChannel,SendMessages,SendMessagesInThreads,EmbedLinks,AttachFiles,ReadMessageHistory,AddReactions,UseExternalEmojis,ManageMessages,ManageThreads,MentionEveryone,ManageRoles,ManageWebhooks
# Integer (bitwise OR of permission bits) for invite URL: &permissions=PERMISSION_INTEGER
# Below = ViewChannel(1024) + SendMessages(2048) + EmbedLinks(16384) + ReadMessageHistory(65536) + ManageRoles(268435456) + ManageChannels(16) + AddReactions(64)
permission_integer=275146673216
# Scopes for OAuth2 invite (bot + applications.commands optional)
scopes=bot,applications.commands

[DISCORD_INTENTS]
# Gateway intents the bot must request (discord.js GatewayIntentBits)
Guilds=1
GuildMessages=1
MessageContent=1
GuildMembers=1
DirectMessages=1
GuildPresences=0

[CHANNELS]
# Channel IDs for Donny notifies (ANNOUNCEMENTS = ANNOUNCEMENTS_CHANNEL_ID, CHAT = CHAT_CHANNEL_ID in bot)
LOGIN_NOTIFY=ANNOUNCEMENTS
REGISTER_NOTIFY=ANNOUNCEMENTS
NEW_USER_LIVE_PAGE_VISIT=CHAT
KEY_REDEEM_NOTIFY=ANNOUNCEMENTS
AUTOMATES_NOTIFYS=ANNOUNCEMENTS

[INVITE_URL]
# Re-invite bot with Donny permissions (replace YOUR_CLIENT_ID with Discord app client ID):
# https://discord.com/api/oauth2/authorize?client_id=YOUR_CLIENT_ID&permissions=275146673216&scope=bot%20applications.commands
